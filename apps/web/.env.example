# ─────────────────────────────────────────
# Peteen — variáveis de ambiente
# Copiar para .env.local e preencher os valores.
# NUNCA commitar .env.local ou .env com valores reais.
# ─────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Supabase ───────────────────────────
# Encontrar em: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key — NUNCA expor ao browser
# Usar apenas em operações server-side privilegiadas
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database / Prisma ──────────────────
# Encontrar em: Supabase Dashboard → Settings → Database → Connection string
#
# DATABASE_URL: usa o Supabase connection pooler (porta 6543 com pgbouncer)
# → para runtime da aplicação (Server Actions, queries de negócio)
#
# DIRECT_URL: conexão direta PostgreSQL (porta 5432)
# → apenas para prisma migrate (não usa pooler)

DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Auth Providers (configurar no Supabase Dashboard) ──
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Maps & Geolocalização ──────────────
# Necessário para ranking local e descoberta por densidade
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Analytics ──────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Email ──────────────────────────────
RESEND_API_KEY=

# ─── Monitoramento ──────────────────────
SENTRY_DSN=
